---
// Everything below must be inside the triple-dashes
import { getCollection } from 'astro:content';
import MainLayout from '../../layouts/MainLayout.astro';

export async function getStaticPaths() {
  const blogEntries = await getCollection('blog');
  return blogEntries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const tags = entry.data.tags || [];
---
<MainLayout title={`${entry.data.title} | DadWritesTech`} description={entry.data.description}>
  <article class="max-w-3xl mx-auto">
    <header class="mb-8 pb-8 border-b border-slate-200 dark:border-slate-800">
      <h1 class="text-3xl md:text-4xl font-bold mb-4 text-slate-900 dark:text-slate-100">{entry.data.title}</h1>
      <div class="flex flex-wrap items-center gap-4 text-sm text-slate-500 dark:text-slate-400">
        <time datetime={entry.data.pubDate.toISOString()}>
          {entry.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
        {entry.data.updatedDate && (
          <span class="text-slate-400">Updated: {entry.data.updatedDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
        )}
        <span>By {entry.data.authors?.[0] || 'DadWritesTech'}</span>
      </div>
      {tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mt-4">
          {tags.map(tag => (
            <span class="px-2 py-1 text-xs rounded-full bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-400">#{tag}</span>
          ))}
        </div>
      )}
    </header>
    <style is:global>
      [data-callout-type] {
        padding: 1rem 1.25rem; margin: 1.25rem 0; border-radius: 0.5rem; border-left: 4px solid;
      }
      [data-callout-title] { font-weight: 700; margin-bottom: 0.25rem; text-transform: capitalize; }
      [data-callout-body] { margin: 0; }
      [data-callout-type="info"] { background-color: #eff6ff; color: #1e3a8a; border-color: #3b82f6; }
      [data-callout-type="warning"] { background-color: #fffbeb; color: #78350f; border-color: #f59e0b; }
      [data-callout-type="note"] { background-color: #f8fafc; color: #1e293b; border-color: #94a3b8; }
      [data-callout-type="success"] { background-color: #f0fdf4; color: #166534; border-color: #22c55e; }
      [data-callout-type="danger"] { background-color: #fef2f2; color: #7f1d1d; border-color: #ef4444; }
      :root.dark [data-callout-type] { background-color: rgba(148,163,184,0.12) !important; color: #cbd5e1 !important; }
      :root.dark [data-callout-type="info"] { background-color: rgba(59,130,246,0.15) !important; color: #93c5fd !important; border-color: #60a5fa !important; }
      :root.dark [data-callout-type="warning"] { background-color: rgba(245,158,11,0.15) !important; color: #fcd34d !important; border-color: #fbbf24 !important; }
      :root.dark [data-callout-type="success"] { background-color: rgba(34,197,94,0.15) !important; color: #86efac !important; border-color: #4ade80 !important; }
      :root.dark [data-callout-type="danger"] { background-color: rgba(239,68,68,0.15) !important; color: #fca5a5 !important; border-color: #f87171 !important; }
    </style>
    <div class="prose prose-slate dark:prose-invert max-w-none">
      <Content />
    </div>
  </article>
</MainLayout>
